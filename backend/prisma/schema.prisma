// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TipoDiabetes {
  NENHUM
  TIPO1
  TIPO2
  GESTACIONAL
  PRE_DIABETES
}

enum StatusUsuario {
  ATIVO
  INATIVO
}

enum Perfil {
  USUARIO
  ADMIN
}

enum Humor {
  OTIMO
  BOM
  OK
  MAL
  PESSIMO
}

enum Categoria {
  EXERCICIO
  ALIMENTACAO
  EMERGENCIA
  BEM_ESTAR
}

enum CategoriaFAQ {
  DIABETES
  SINTOMAS
  ALIMENTACAO
  EXERCICIOS
  MEDICACAO
  MONITORAMENTO
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Usuario {
  id             String        @id @default(uuid())
  nome           String
  email          String        @unique
  senha          String
  idade          Int?
  peso           Float?
  altura         Float?
  tipoDiabetes   TipoDiabetes  @default(NENHUM)
  glicoseAlvoMin Float?
  glicoseAlvoMax Float?
  nomeMedico     String?
  ultimaConsulta DateTime?
  status         StatusUsuario @default(ATIVO)
  perfil         Perfil        @default(USUARIO)
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt

  diarios Diario[]

  @@map("usuarios")
}

model Diario {
  id           String   @id @default(uuid())
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  titulo       String
  conteudo     String
  humor        Humor
  sintomas     String[]
  tags         String[]
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("diarios")
}

model Dicas {
  id            String   @id @default(uuid())
  titulo        String
  sumario       String
  conteudo      String
  categoria     Categoria
  tempoLeitura  Int
  destaque      Boolean  @default(false)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@map("dicas")
}

model FAQ {
  id           String       @id @default(uuid())
  pergunta     String
  resposta     String
  categoria    CategoriaFAQ
  ordem        Int          @default(0)
  ativo        Boolean      @default(true)
  criadoEm    DateTime     @default(now())
  atualizadoEm DateTime    @updatedAt

  @@map("faqs")
}